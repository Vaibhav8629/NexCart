# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL of the backend API. The Vite proxy (/api) handles this in development,
# so this is used for production builds or direct API references.
VITE_API_URL=http://localhost:5000

# Google OAuth is handled by the backend; no frontend client secret is needed.
# This base URL is used to send the browser to the backend Google login route.

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Your Stripe publishable key (starts with pk_test_ or pk_live_)
# This key is safe to expose to the frontend.
VITE_STRIPE_PUBLISHABLE_KEY=
