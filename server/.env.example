# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server will listen on
PORT=5000

# Node environment: development | production
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Full MongoDB connection URI (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/NexCart

# ─── Authentication ───────────────────────────────────────────────────────────
# A long random string used to sign JWT tokens. Keep this secret.
JWT_SECRET=

# Google OAuth client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=

# Google OAuth client secret from Google Cloud Console.
GOOGLE_CLIENT_SECRET=

# Must match the Google OAuth callback URL registered in Google Cloud Console.
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL used to redirect users back after Google login completes.
CLIENT_URL=http://localhost:5173

# ─── Stripe Payments ──────────────────────────────────────────────────────────
# Your Stripe secret key (starts with sk_test_ or sk_live_)
# NEVER expose this to the frontend
STRIPE_SECRET_KEY=

# Webhook signing secret from the Stripe dashboard → Webhooks
# Used to verify that incoming webhook events are genuine Stripe events
STRIPE_WEBHOOK_SECRET=
