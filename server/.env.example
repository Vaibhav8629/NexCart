# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server will listen on
PORT=5000

# Node environment: development | production
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Full MongoDB connection URI (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/NexCart

# ─── Authentication ───────────────────────────────────────────────────────────
# A long random string used to sign JWT tokens. Keep this secret.
JWT_SECRET=

# ─── Stripe Payments ──────────────────────────────────────────────────────────
# Your Stripe secret key (starts with sk_test_ or sk_live_)
# NEVER expose this to the frontend
STRIPE_SECRET_KEY=

# Webhook signing secret from the Stripe dashboard → Webhooks
# Used to verify that incoming webhook events are genuine Stripe events
STRIPE_WEBHOOK_SECRET=
